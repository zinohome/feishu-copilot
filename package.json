{
  "name": "feishu-copilot-bridge",
  "version": "0.0.27",
  "private": true,
  "publisher": "feishu-copilot",
  "displayName": "Feishu Copilot Bridge",
  "description": "Bridge Feishu private chat to VS Code Copilot",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/src/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "feishu-copilot.chat",
        "name": "feishu",
        "fullName": "Feishu Copilot",
        "description": "Chat with Copilot, synced with Feishu",
        "isDefault": true,
        "locations": [
          "panel"
        ]
      }
    ],
    "chatSessions": [
      {
        "type": "feishu",
        "name": "Feishu Sessions"
      }
    ],
    "commands": [
      {
        "command": "feishu-copilot.start",
        "title": "Feishu Copilot: Start Bridge"
      },
      {
        "command": "feishu-copilot.stop",
        "title": "Feishu Copilot: Stop Bridge"
      },
      {
        "command": "feishu-copilot.restart",
        "title": "Feishu Copilot: Restart Bridge"
      },
      {
        "command": "feishu-copilot.status",
        "title": "Feishu Copilot: Show Status"
      },
      {
        "command": "feishu-copilot.openSettings",
        "title": "Feishu Copilot: Open Settings"
      },
      {
        "command": "feishu-copilot.openLatestSharedSession",
        "title": "Feishu Copilot: Open Latest Shared Session"
      }
    ],
    "configuration": {
      "title": "Feishu Copilot Bridge",
      "properties": {
        "feishuCopilot.feishuAppId": {
          "type": "string",
          "default": "",
          "description": "Feishu application ID (required)."
        },
        "feishuCopilot.feishuAppSecret": {
          "type": "string",
          "default": "",
          "description": "Feishu application secret (required)."
        },
        "feishuCopilot.ownerOpenId": {
          "type": "string",
          "default": "",
          "description": "Allowed Feishu sender open_id. Messages from other senders are ignored."
        },
        "feishuCopilot.superpowersSourcePath": {
          "type": "string",
          "default": "",
          "description": "Absolute path of Superpowers extension root. If empty, auto-detect from ~/.vscode/extensions."
        },
        "feishuCopilot.sharedStorePath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to shared sessions.json. Used when no workspace folder is available."
        },
        "feishuCopilot.allowGlobalStorageFallback": {
          "type": "boolean",
          "default": true,
          "description": "Allow fallback to editor-local globalStorage when shared path is unavailable."
        }
      }
    }
  },
  "extensionKind": [
    "ui"
  ],
  "enabledApiProposals": [
    "chatSessionsProvider"
  ],
  "engines": {
    "node": ">=22",
    "vscode": "^1.100.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "tsc -p tsconfig.json",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/vscode": "^1.100.0",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.60.0"
  }
}
